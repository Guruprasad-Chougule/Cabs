// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  admin
  driver
  super_admin
}

enum TripType {
  one_way
  round_trip
  multi_day
}

enum BookingStatus {
  pending
  confirmed
  assigned
  in_progress
  completed
  cancelled
}

enum PaymentStatus {
  unpaid
  partial
  paid
  refunded
}

enum VehicleType {
  sedan
  suv
  innova
  tempo_traveller
  mini_bus
}

enum PaymentMethod {
  upi
  credit_card
  debit_card
  net_banking
  wallet
  cash
}

enum EnquiryStatus {
  new
  responded
  closed
}

model User {
  id            String    @id @default(uuid())
  name          String    @db.VarChar(100)
  email         String?   @unique @db.VarChar(255)
  phone         String    @unique @db.VarChar(15)
  role          UserRole  @default(customer)
  passwordHash  String?   @map("password_hash") @db.VarChar(255)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  bookings      Booking[]
  driver        Driver?
  reviews       Review[]

  @@map("users")
}

model Driver {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  licenseNumber   String    @unique @map("license_number") @db.VarChar(30)
  licenseExpiry   DateTime  @map("license_expiry")
  experienceYears Int       @map("experience_years")
  rating          Decimal   @default(5.0) @db.Decimal(3, 2)
  isAvailable     Boolean   @default(true) @map("is_available")
  photoUrl        String?   @map("photo_url")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user            User      @relation(fields: [userId], references: [id])
  bookings        Booking[]
  vehicle         Vehicle?  @relation(fields: [vehicleId], references: [id])
  vehicleId       String?   @map("vehicle_id")

  @@map("drivers")
}

model Vehicle {
  id             String      @id @default(uuid())
  type           VehicleType
  make           String      @db.VarChar(50)
  model          String      @db.VarChar(50)
  registrationNo String      @unique @map("registration_no") @db.VarChar(20)
  capacity       Int
  ac             Boolean     @default(true)
  ratePerKm      Decimal     @map("rate_per_km") @db.Decimal(6, 2)
  ratePerDay     Decimal?    @map("rate_per_day") @db.Decimal(8, 2)
  imageUrl       String?     @map("image_url")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  bookings       Booking[]
  drivers        Driver[]

  @@map("vehicles")
}

model Route {
  id            String    @id @default(uuid())
  slug          String    @unique @db.VarChar(100)
  origin        String    @db.VarChar(100)
  destination   String    @db.VarChar(100)
  distanceKm    Decimal   @map("distance_km") @db.Decimal(8, 2)
  durationHours Decimal   @map("duration_hours") @db.Decimal(5, 2)
  description   String?   @db.Text
  highlights    String[]
  imageUrl      String?   @map("image_url")
  isFeatured    Boolean   @default(false) @map("is_featured")
  metaTitle     String?   @map("meta_title")
  metaDesc      String?   @map("meta_desc")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("routes")
}

model TourPackage {
  id             String    @id @default(uuid())
  slug           String    @unique @db.VarChar(100)
  title          String    @db.VarChar(200)
  destination    String    @db.VarChar(100)
  durationDays   Int       @map("duration_days")
  durationNights Int       @map("duration_nights")
  description    String?   @db.Text
  highlights     String[]
  inclusions     String[]
  exclusions     String[]
  basePrice      Decimal   @map("base_price") @db.Decimal(10, 2)
  imageUrl       String?   @map("image_url")
  isActive       Boolean   @default(true) @map("is_active")
  category       String    @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("tour_packages")
}

model Booking {
  id                   String        @id @default(uuid())
  bookingRef           String        @unique @map("booking_ref") @db.VarChar(20)
  userId               String        @map("user_id")
  driverId             String?       @map("driver_id")
  vehicleId            String?       @map("vehicle_id")
  tripType             TripType      @map("trip_type")
  pickupLocation       String        @map("pickup_location") @db.Text
  pickupLat            Decimal       @map("pickup_lat") @db.Decimal(10, 7)
  pickupLng            Decimal       @map("pickup_lng") @db.Decimal(10, 7)
  dropLocation         String        @map("drop_location") @db.Text
  dropLat              Decimal       @map("drop_lat") @db.Decimal(10, 7)
  dropLng              Decimal       @map("drop_lng") @db.Decimal(10, 7)
  pickupDatetime       DateTime      @map("pickup_datetime")
  returnDatetime       DateTime?     @map("return_datetime")
  passengers           Int
  estimatedDistanceKm  Decimal?      @map("estimated_distance_km") @db.Decimal(8, 2)
  estimatedFare        Decimal?      @map("estimated_fare") @db.Decimal(10, 2)
  finalFare            Decimal?      @map("final_fare") @db.Decimal(10, 2)
  status               BookingStatus @default(pending)
  paymentStatus        PaymentStatus @default(unpaid) @map("payment_status")
  specialInstructions  String?       @map("special_instructions") @db.Text
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  user                 User          @relation(fields: [userId], references: [id])
  driver               Driver?       @relation(fields: [driverId], references: [id])
  vehicle              Vehicle?      @relation(fields: [vehicleId], references: [id])
  payments             Payment[]
  reviews              Review[]

  @@map("bookings")
}

model Payment {
  id              String        @id @default(uuid())
  bookingId       String        @map("booking_id")
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  transactionId   String?       @map("transaction_id") @db.VarChar(100)
  gatewayResponse Json?         @map("gateway_response")
  status          PaymentStatus
  createdAt       DateTime      @default(now()) @map("created_at")

  booking         Booking       @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  bookingId String?  @map("booking_id")
  rating    Int
  comment   String?  @db.Text
  isApproved Boolean @default(false) @map("is_approved")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])
  booking   Booking? @relation(fields: [bookingId], references: [id])

  @@map("reviews")
}

model PricingRule {
  id             String      @id @default(uuid())
  vehicleType    VehicleType @map("vehicle_type")
  tripType       TripType    @map("trip_type")
  baseFare       Decimal     @map("base_fare") @db.Decimal(8, 2)
  perKmRate      Decimal     @map("per_km_rate") @db.Decimal(6, 2)
  perHourRate    Decimal?    @map("per_hour_rate") @db.Decimal(6, 2)
  nightSurcharge Decimal     @default(0) @map("night_surcharge") @db.Decimal(5, 2)
  driverBatta    Decimal     @default(0) @map("driver_batta") @db.Decimal(8, 2)
  gstPercent     Decimal     @default(5) @map("gst_percent") @db.Decimal(5, 2)
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@unique([vehicleType, tripType])
  @@map("pricing_rules")
}

model Enquiry {
  id        String        @id @default(uuid())
  name      String        @db.VarChar(100)
  email     String        @db.VarChar(255)
  phone     String        @db.VarChar(15)
  subject   String        @db.VarChar(200)
  message   String        @db.Text
  status    EnquiryStatus @default(new)
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("enquiries")
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String   @db.VarChar(15)
  otp       String   @db.VarChar(6)
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("otp_verifications")
}
